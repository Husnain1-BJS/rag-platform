QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PATH=./qdrant_data
COLLECTION_NAME=threat_intel
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM Model (nemotron-3-ultra is slow on free tier ~18-23s; try faster models if available)
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Alternatives (often unavailable on free tier):
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# OPENROUTER_MODEL=google/gemma-2-9b-it:free
RAGAS_EVAL_MODEL=meta-llama/llama-3.1-8b-instruct:free
NVD_API_KEY=

ENABLE_HYBRID_SEARCH=true
SPARSE_MODEL=Qdrant/bm25
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ENABLE_RERANKING=true
RERANK_TOP_K=20
FINAL_TOP_K=5

# LLM Performance Tuning
LLM_MAX_TOKENS=512
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.1

# Auth & Rate Limiting
API_KEY=
RATE_LIMIT_PER_MINUTE=30